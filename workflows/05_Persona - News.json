    {
      "parameters": {
        "jsCode": "return $input.all().map(it => {\n  const j = it.json;\n  return { json: {\n    source: 'BBC News',\n    title: (j.title || '').toString().trim(),\n    url: (j.link || j.url || '').toString().trim(),\n    summary: (j.contentSnippet || j.content || j.description || '').toString().replace(/<[^>]*>/g, '').replace(/\\s+/g, ' ').trim(),\n    date: (j.isoDate || j.pubDate || '').toString().trim()\n  }};\n});\n"
      },
