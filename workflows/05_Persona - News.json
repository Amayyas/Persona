      "id": "73b7bcc8-2499-4064-828f-cdf190284a37",
      "name": "Merge the Sources",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [
        480,
        208
      ]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all().map(i => i.json);\n\nfunction normTitle(t) {\n  return (t || '').toString().toLowerCase().replace(/[^a-z0-9]+/g, ' ').trim();\n}\nfunction normUrl(u) {\n  return (u || '').toString().toLowerCase().split('?')[0].replace(/\\/+$/, '');\n}\n\nconst seenUrl = new Set();\nconst seenTitle = new Set();\nconst result = [];\n\nfor (const a of items) {\n  const urlKey = normUrl(a.url);\n  const titleKey = normTitle(a.title);\n  if (!urlKey && !titleKey) continue;\n  if (urlKey && seenUrl.has(urlKey)) continue;\n  if (titleKey && seenTitle.has(titleKey)) continue;\n  if (urlKey) seenUrl.add(urlKey);\n  if (titleKey) seenTitle.add(titleKey);\n  result.push(a);\n}\n\nreturn result.map(a => ({ json: a }));\n"
      },
